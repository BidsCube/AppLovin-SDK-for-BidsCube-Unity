# Normalize text for cross-platform clones (GitHub / Unity)
* text=auto

*.cs     text eol=lf
*.md     text eol=lf
*.json   text eol=lf
*.xml    text eol=lf
*.gradle text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.sh     text eol=lf

# Unity YAML scenes (if ever added under package)
*.unity  text eol=lf

*.aar binary
*.png   binary
*.jpg   binary
